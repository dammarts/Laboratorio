# ============================================================
# VARIABLES DE ENTORNO — Sistema Reservas Laboratorios
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio (está en .gitignore).
# ============================================================


# ------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# En Docker el servidor es "db"; en local usa "localhost"
# ------------------------------------------------------------
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=reservas
DB_USER=postgres
DB_PASSWORD=YourStrong!Password123


# ------------------------------------------------------------
# BACKEND (FastAPI)
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development


# ------------------------------------------------------------
# JWT
# JWT_SECRET_KEY: mínimo 32 caracteres aleatorios
# JWT_ALGORITHM: no cambiar salvo decisión de equipo
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: tiempo de vida del token
# ------------------------------------------------------------
JWT_SECRET_KEY=cambia_esto_por_una_clave_muy_larga_y_segura_min32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60


# ------------------------------------------------------------
# CORS
# Orígenes permitidos separados por coma.
# Ajustar en producción a la URL real del frontend.
# ------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:5173


# ------------------------------------------------------------
# SEED — primer usuario ADMIN (ejecutar una sola vez)
# Después de seedear, estas variables ya no son necesarias.
# ------------------------------------------------------------
SEED_EMAIL=admin@universidad.edu
SEED_PASSWORD=CambiarEsto!Admin123


# ------------------------------------------------------------
# FRONTEND (Vite)
# URL base que el frontend usa para llamar al backend.
# En producción cambiar por la URL pública del backend.
# ------------------------------------------------------------
VITE_API_URL=http://localhost:8000


# ------------------------------------------------------------
# TESTS E2E (Playwright)
# Credenciales de usuarios ya sembrados en la BD de pruebas.
# ------------------------------------------------------------
E2E_ADMIN_EMAIL=admin@universidad.edu
E2E_ADMIN_PASSWORD=CambiarEsto!Admin123
E2E_DOCENTE_EMAIL=docente@universidad.edu
E2E_DOCENTE_PASSWORD=CambiarEsto!Docente123


# ------------------------------------------------------------
# PRUEBAS DE CARGA (Locust / k6)
# Usuarios que generan tráfico sintético contra el backend.
# Pueden ser los mismos que los de E2E o cuentas separadas.
# ------------------------------------------------------------
LOAD_ADMIN_EMAIL=admin@universidad.edu
LOAD_ADMIN_PASSWORD=CambiarEsto!Admin123
LOAD_DOCENTE_EMAIL=docente@universidad.edu
LOAD_DOCENTE_PASSWORD=CambiarEsto!Docente123


# ------------------------------------------------------------
# SONARCLOUD — Análisis estático de calidad
# Obtener el token en sonarcloud.io → My Account → Security.
# Configurar también como secret en GitHub Actions.
# ------------------------------------------------------------
SONAR_TOKEN=pendiente
