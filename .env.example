# VARIABLES DE ENTORNO — Sistema Reservas Laboratorios
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env al repositorio

# Base de datos
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=reservas
DB_USER=sa
DB_PASSWORD=YourStrong!Password123

# Aplicación
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# JWT
JWT_SECRET_KEY=cambia_esto_por_una_clave_muy_larga_y_segura
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173