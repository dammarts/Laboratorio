# ============================================================
# VARIABLES DE ENTORNO — Backend (FastAPI)
# Copia este archivo como .env dentro de backend/ y completa
# los valores reales. NUNCA subas .env al repositorio.
# ============================================================


# ------------------------------------------------------------
# BASE DE DATOS (SQL Server)
# En Docker el servidor es "db"; en local usa "localhost"
# ------------------------------------------------------------
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=reservas
DB_USER=sa
DB_PASSWORD=YourStrong!Password123


# ------------------------------------------------------------
# BACKEND (FastAPI)
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development


# ------------------------------------------------------------
# JWT
# JWT_SECRET_KEY: mínimo 32 caracteres aleatorios
# JWT_ALGORITHM: no cambiar salvo decisión de equipo
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: tiempo de vida del token
# ------------------------------------------------------------
JWT_SECRET_KEY=cambia_esto_por_una_clave_muy_larga_y_segura_min32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60


# ------------------------------------------------------------
# CORS
# Orígenes permitidos separados por coma.
# Ajustar en producción a la URL real del frontend.
# ------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:5173


# ------------------------------------------------------------
# SEED — primer usuario ADMIN (ejecutar una sola vez)
# Después de seedear, estas variables ya no son necesarias.
# ------------------------------------------------------------
SEED_EMAIL=admin@universidad.edu
SEED_PASSWORD=CambiarEsto!Admin123


# ------------------------------------------------------------
# SONARCLOUD — Análisis estático de calidad
# Obtener el token en sonarcloud.io → My Account → Security.
# Configurar también como secret en GitHub Actions.
# ------------------------------------------------------------
SONAR_TOKEN=pendiente
